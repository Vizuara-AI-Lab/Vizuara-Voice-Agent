# Required: Your OpenAI API key (needs access to gpt-4o-realtime-preview)
OPENAI_API_KEY=sk-proj-...

# Optional: Server port (default 3000)
PORT=3000

# ─── Voice Provider ──────────────────────────────────────────────────────────
# Switch between "openai" (GPT-4o Realtime) and "vapi" (VAPI agent)
# Change this to "vapi" to quickly switch when OpenAI costs rise
VOICE_PROVIDER=openai

# ─── Cost Controls ───────────────────────────────────────────────────────────
# Maximum call duration in seconds (default: 300 = 5 minutes)
MAX_CALL_DURATION_SECONDS=300

# Daily budget in USD. Set to 0 for unlimited. New calls blocked when exceeded.
DAILY_BUDGET_USD=0

# Cost per minute estimates (USD) — used for tracking, adjust to match actual rates
# gpt-4o-realtime: ~$0.06/min audio input + ~$0.24/min audio output = ~$0.30/min
# gpt-4o-mini-realtime: ~$0.05/min
COST_PER_MIN_REALTIME=0.30
COST_PER_MIN_MINI=0.05
COST_PER_MIN_VAPI=0.07

# ─── VAPI Configuration (only needed if VOICE_PROVIDER=vapi) ─────────────────
# Your VAPI API key (public key, used client-side)
VAPI_API_KEY=
# The VAPI assistant ID (e.g., Vikrant agent)
VAPI_ASSISTANT_ID=
# VAPI server API key (private key, used to fetch call analytics from VAPI API)
VAPI_SERVER_API_KEY=
